---
import "../styles/disclosure.css";

interface Props {
  title?: string;
  text: string;
}

const { title = "Affiliate disclosure", text } = Astro.props;
---

<div class="disclosure">
  <div class="dico">
    <svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="1.6" aria-hidden="true">
      <path d="M12 3l8 4v5c0 4.5-3.2 7.5-8 9-4.8-1.5-8-4.5-8-9V7l8-4z"></path>
      <path d="M9 12l2 2 4-4"></path>
    </svg>
  </div>
  <div>
    <h4>{title}</h4>
    <p>{text}</p>
  </div>
</div>
