---
interface Props {
  count: number;
}

const { count } = Astro.props;
---

<div class="find-count" id="findCount">
  <span class="fc-num" id="fcNum">{count}</span>
  <span class="fc-label" id="fcLabel">field notes in the diary</span>
  <button class="fc-reset" id="fcReset" type="button">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
      <path d="M3 12a9 9 0 1 0 3-6.7M3 4v4h4"></path>
    </svg>
    Clear all
  </button>
</div>
