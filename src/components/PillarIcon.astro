---
interface Props {
  pillar: "earns" | "builds" | "invests" | "lives" | "learns";
}

const { pillar } = Astro.props;
---

{
  pillar === "earns" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
      <circle cx="12" cy="12" r="8"></circle>
      <path d="M12 8v8M9.5 14c0 1.4 1.1 2 2.5 2s2.5-.6 2.5-1.8c0-2.4-5-1.4-5-3.6 0-1.1 1-1.8 2.5-1.8s2.5.7 2.5 1.7"></path>
    </svg>
  )
}
{
  pillar === "builds" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
      <path d="M4 20V9l5-4 5 4M14 20V12l3-2.4 3 2.4V20M3 20h18"></path>
    </svg>
  )
}
{
  pillar === "invests" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
      <path d="M4 17l5-5 3 3 7-7M15 8h4v4M4 20h16"></path>
    </svg>
  )
}
{
  pillar === "lives" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2"></path>
    </svg>
  )
}
{
  pillar === "learns" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
      <path d="M4 5.5A2.5 2.5 0 016.5 3H12v16H6.5A2.5 2.5 0 004 21V5.5zM20 5.5A2.5 2.5 0 0017.5 3H12v16h5.5a2.5 2.5 0 012.5 2.5V5.5z"></path>
    </svg>
  )
}
