---
import { Image } from "astro:assets";
import femLogo from "../assets/fem-logo.png";
import "../styles/masthead.css";

interface Props {
  active?: "home" | "about" | "resources" | "blog";
}

const { active = "home" } = Astro.props;
const isActive = (page: Props["active"]) => (active === page ? "active" : "");
---

<nav class="mast">
  <div class="mast-inner">
    <a class="mast-logo" href="/" aria-label="SheisFEM home">
      <Image src={femLogo} alt="FEM logo" />
      <div>
        <div class="lw">SheisFEM</div>
        <div class="ls">Female Earning More</div>
      </div>
    </a>
    <div class="mast-nav" id="navLinks">
      <a href="/" class={isActive("home")}>Home</a>
      <a href="/about" class={isActive("about")}>About</a>
      <a href="/resources" class={isActive("resources")}>Resources</a>
      <a href="/blog" class={isActive("blog")}>Blog</a>
      <a href="https://ca.pinterest.com/sheisfem/" target="_blank" rel="noopener">Pinterest</a>
      <a class="mast-cta" href="https://www.instagram.com/sheisfem/" target="_blank" rel="noopener">
        Follow
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </div>
    <button class="mast-burger" id="navBurger" type="button" aria-label="Menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>
  </div>
</nav>
