---
import { getCollection } from "astro:content";
import Disclosure from "../components/Disclosure.astro";
import FolioBar from "../components/FolioBar.astro";
import PillarIcon from "../components/PillarIcon.astro";
import ResourceRow from "../components/ResourceRow.astro";
import { getPillarResources, getResourceCta, getResourceIcon, pillars } from "../data/resources";
import BaseLayout from "../layouts/BaseLayout.astro";

const resources = await getCollection("resources");
const numberWords = ["Zero", "One", "Two", "Three", "Four", "Five"];
const countLabel = (count: number) => {
  const countText = numberWords[count] ?? String(count);

  return `${countText} ${count === 1 ? "tool" : "tools"}`;
};
---

<BaseLayout title="Resources — SheisFEM" active="resources">
  <header class="res-cover wrap" data-screen-label="Resources — Cover">
    <FolioBar left="Tools & Resources" middle="The directory" right="Curated for Canada" />
    <div class="rc-inner">
      <h1>Tools we <em>actually</em> use.</h1>
      <p class="sub">
        Curated for Canadian women. Organized by what you're working on — earning, building,
        investing, living, learning.
      </p>
      <p class="tagline">— resources worth saving, not just scrolling past.</p>
    </div>
  </header>

  <div class="tabs-bar">
    <div class="wrap">
      <div class="tabs" id="tabs">
        <button class="tab active" type="button" data-filter="all">All</button>
        <button class="tab" type="button" data-filter="earns">Earns</button>
        <button class="tab" type="button" data-filter="builds">Builds</button>
        <button class="tab" type="button" data-filter="invests">Invests</button>
        <button class="tab" type="button" data-filter="lives">Lives</button>
        <button class="tab" type="button" data-filter="learns">Learns</button>
      </div>
    </div>
  </div>

  <main class="wrap" id="directory">
    {
      pillars.map((pillar) => {
        const pillarResources = getPillarResources(resources, pillar.key);

        return (
          <section class="pillar-block" data-pillar={pillar.key} id={pillar.key}>
            <div class="pb-head">
              <span class="pb-num">{pillar.num}</span>
              <div class="pb-titles">
                <span class="chip">
                  <PillarIcon pillar={pillar.key} />
                  {pillar.chip}
                </span>
                <h2>{pillar.title}</h2>
                <div class="pb-count">{countLabel(pillarResources.length)}</div>
              </div>
            </div>
            <div class="r-list">
              {pillarResources.map((resource) => (
                <ResourceRow
                  href={resource.data.url}
                  icon={getResourceIcon(resource.data.name)}
                  name={resource.data.name}
                  description={resource.data.description}
                  cta={getResourceCta(resource.data.name)}
                  external
                />
              ))}
            </div>
          </section>
        );
      })
    }

    <div class="empty" id="empty">
      <span class="serif">Nothing here yet.</span>
      <p>More tools are on their way for this pillar.</p>
    </div>
  </main>

  <section class="section tight bg-cream" id="disclosure" data-screen-label="Resources — Disclosure">
    <div class="wrap">
      <Disclosure text="Some links on this page are affiliate links. If you click through and make a purchase, SheisFEM may earn a small commission at no extra cost to you. We only recommend tools we believe in." />
    </div>
  </section>

  <script>
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>(".tab"));
    const blocks = Array.from(document.querySelectorAll<HTMLElement>(".pillar-block"));
    const empty = document.getElementById("empty");
    const valid = ["earns", "builds", "invests", "lives", "learns"];

    const applyFilter = (filter: string) => {
      let anyVisible = false;
      blocks.forEach((block) => {
        const show = filter === "all" || block.dataset.pillar === filter;
        block.style.display = show ? "" : "none";
        if (show) {
          anyVisible = true;
        }
      });
      empty?.classList.toggle("show", !anyVisible);
      tabs.forEach((tab) => {
        tab.classList.toggle("active", tab.dataset.filter === filter);
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const filter = tab.dataset.filter ?? "all";
        applyFilter(filter);
        if (history.replaceState) {
          history.replaceState(null, "", filter === "all" ? location.pathname : `#${filter}`);
        }
      });
    });

    const hash = (location.hash || "").replace("#", "");
    if (valid.includes(hash)) {
      applyFilter(hash);
    }
  </script>
</BaseLayout>
