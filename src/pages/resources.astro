---
import { getCollection } from "astro:content";
import Disclosure from "../components/Disclosure.astro";
import FolioBar from "../components/FolioBar.astro";
import ResourceRow from "../components/ResourceRow.astro";
import {
  getResourceCta,
  getResourceIcon,
  getSectionResources,
  resourceSections,
} from "../data/resources";
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/resources.css";

const resources = await getCollection("resources");
const countLabel = (count: number) => `${count} ${count === 1 ? "resource" : "resources"}`;
---

<BaseLayout title="Resources — SheisFEM" active="resources">
  <header class="res-cover wrap" data-screen-label="Resources — Cover">
    <FolioBar left="Tools & Resources" middle="The directory" right="Curated for Canada" />
    <div class="rc-inner">
      <div class="rc-copy">
        <h1>Resources we<br /><em>actually</em> use.</h1>
        <p class="tagline">— worth saving, not just scrolling past.</p>
        <p class="sub">
          Curated for Canadian women. The tools, books, and media we actually return to — each tied
          to the pillar it supports.
        </p>
      </div>
      <aside class="rc-ledger" aria-label="Resource directory summary">
        <div class="rc-ledger-total">{countLabel(resources.length)}</div>
        <div class="rc-ledger-rows">
          {
            resourceSections.map((section) => (
              <div class="rc-ledger-row">
                <span>{section.title}</span>
                <strong>{getSectionResources(resources, section.key).length}</strong>
              </div>
            ))
          }
        </div>
      </aside>
    </div>
  </header>

  <div class="tabs-bar">
    <div class="wrap">
      <div class="tabs" id="tabs">
        {
          resourceSections.map((section, index) => (
            <button
              class:list={["tab", { active: index === 0 }]}
              type="button"
              data-filter={section.key}
            >
              {section.title}
            </button>
          ))
        }
      </div>
    </div>
  </div>

  <main class="wrap" id="directory">
    {
      resourceSections.map((section) => {
        const sectionResources = getSectionResources(resources, section.key);

        return (
          <section class="pillar-block" data-section={section.key} id={section.key}>
            <div class="pb-head">
              <span class="pb-num">{section.num}</span>
                <div class="pb-titles">
                  <h2>{section.title}</h2>
                  <p class="pb-subtitle">{section.subtitle}</p>
                  <div class="pb-count">{countLabel(sectionResources.length)}</div>
              </div>
            </div>
            <div class="r-list">
              {sectionResources.map((resource) => (
                <ResourceRow
                  href={resource.data.url}
                  icon={getResourceIcon(resource.data.name)}
                  name={resource.data.name}
                  description={resource.data.description}
                  pillars={resource.data.pillars}
                  cta={getResourceCta(resource.data.type)}
                  external
                />
              ))}
            </div>
          </section>
        );
      })
    }

    <div class="empty" id="empty">
      <span class="serif">Nothing here yet.</span>
      <p>More tools are on their way for this pillar.</p>
    </div>
  </main>

  <section class="section tight bg-cream" id="disclosure" data-screen-label="Resources — Disclosure">
    <div class="wrap">
      <Disclosure text="Some links on this page are affiliate links. If you click through and make a purchase, SheisFEM may earn a small commission at no extra cost to you. We only recommend tools we believe in." />
    </div>
  </section>

  <script>
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>(".tab"));
    const blocks = Array.from(document.querySelectorAll<HTMLElement>(".pillar-block"));
    const empty = document.getElementById("empty");
    const valid = ["explore", "read", "listen"];

    const applyFilter = (filter: string) => {
      let anyVisible = false;
      let firstVisibleBlock: HTMLElement | undefined;
      blocks.forEach((block) => {
        const show = block.dataset.section === filter;
        block.style.display = show ? "" : "none";
        if (show) {
          anyVisible = true;
          firstVisibleBlock ??= block;
        }
        block.classList.remove("first-visible");
      });
      firstVisibleBlock?.classList.add("first-visible");
      empty?.classList.toggle("show", !anyVisible);
      tabs.forEach((tab) => {
        tab.classList.toggle("active", tab.dataset.filter === filter);
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const filter = tab.dataset.filter ?? "all";
        applyFilter(filter);
        if (history.replaceState) {
          history.replaceState(null, "", filter === "explore" ? location.pathname : `#${filter}`);
        }
      });
    });

    const hash = (location.hash || "").replace("#", "");
    applyFilter(valid.includes(hash) ? hash : "explore");
  </script>
</BaseLayout>
