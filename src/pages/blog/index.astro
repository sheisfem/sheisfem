---
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../../keystatic.config";
import BlogEntryCard from "../../components/BlogEntryCard.astro";
import BlogFindControls from "../../components/BlogFindControls.astro";
import BlogFindSummary from "../../components/BlogFindSummary.astro";
import BlogIndexHero from "../../components/BlogIndexHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/blog-index.css";

declare const process: { cwd(): string };
const reader = createReader(process.cwd(), keystaticConfig);
const allPosts = await reader.collections.posts.all();

const sorted = [...allPosts].sort((a, b) =>
  (b.entry.publishedDate ?? "").localeCompare(a.entry.publishedDate ?? "")
);

const entryNumbers = new Map(
  [...allPosts]
    .sort((a, b) => (a.entry.publishedDate ?? "").localeCompare(b.entry.publishedDate ?? ""))
    .map((post, i) => [post.slug, i + 1])
);
---

<BaseLayout
  title="Field Notes — SheisFEM"
  description="Read SheisFEM field notes on earning more, building with systems, investing calmly, and making money decisions with more agency."
  active="blog"
>
  <BlogIndexHero />
  <BlogFindControls />

  <main class="wrap diary-main">
    <BlogFindSummary count={sorted.length} />

    {
      sorted.length === 0 ? (
        <div class="bc-empty">
          <span class="serif">No posts yet.</span>
          <p>Field notes are on their way.</p>
        </div>
      ) : (
        <>
          <section class="entries" id="entryList" aria-live="polite">
            {sorted.map(({ slug, entry }, i) => (
              <BlogEntryCard
                slug={slug}
                entry={entry}
                entryNumber={entryNumbers.get(slug) ?? i + 1}
                isLatest={i === 0}
              />
            ))}
          </section>

          <div class="load-more" id="loadWrap" hidden>
            <span class="lm-count" id="loadCount"></span>
            <button id="loadBtn" type="button">
              <span class="lm-label">Load more</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                <path d="M12 5v14M19 12l-7 7-7-7"></path>
              </svg>
            </button>
          </div>

          <div class="find-empty" id="emptyState">
            <span class="fe-script">nothing filed under that...</span>
            <p>No entries match your search. Try a different keyword or browse another pillar.</p>
            <button id="emptyReset" type="button">Reset the diary</button>
          </div>
        </>
      )
    }
  </main>

  <script>
    import "../../scripts/blog-index";
  </script>
</BaseLayout>
