---
import { getCollection } from "astro:content";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";
import FolioBar from "../components/FolioBar.astro";
import PillarIcon from "../components/PillarIcon.astro";
import ResourceRow from "../components/ResourceRow.astro";
import { getFeaturedResources, getResourceIcon } from "../data/resources";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatIsoIssueWeek } from "../lib/issueWeek";
import "../styles/home.css";
import "../styles/home-newsletter.css";

declare const process: { cwd(): string };

const resources = await getCollection("resources");
const featuredResources = getFeaturedResources(resources);
const reader = createReader(process.cwd(), keystaticConfig);
const allPosts = await reader.collections.posts.all();
const recentPosts = [...allPosts]
  .sort((a, b) => (b.entry.publishedDate ?? "").localeCompare(a.entry.publishedDate ?? ""))
  .slice(0, 2);
const currentIssueWeekLabel = formatIsoIssueWeek();

const months = [
  "January",
  "February",
  "March",
  "April",
  "May",
  "June",
  "July",
  "August",
  "September",
  "October",
  "November",
  "December",
];

const formatDate = (dateStr: string | null) => {
  if (!dateStr) return "";
  const [year, month, day] = dateStr.split("-").map(Number);
  return `${months[month - 1]} ${day}, ${year}`;
};

const pillarLabels: Record<string, string> = {
  earns: "She Earns More",
  builds: "She Builds More",
  invests: "She Invests More",
  lives: "She Lives More",
  learns: "She Learns More",
};
---

<BaseLayout title="SheisFEM — Diary of women who earn more" active="home">
  <header class="cover wrap" data-screen-label="Home — Cover">
    <FolioBar
      left={currentIssueWeekLabel}
      middle="Diary of women who earn more"
      right="money chronicles"
      dynamicIssueWeek
    />
    <div class="cover-inner">
      <div class="cover-lede-col">
        <div class="cover-eyebrow">
          <span class="kicker accent">The Diary</span>
          <span class="yr">est. 2019</span>
        </div>
        <h1>Earn more.<br />Build more.<br /><span class="em">Live more.</span></h1>
        <p class="tagline">— on your own terms.</p>
        <p class="lede">
          Tools, resources, and real talk for Canadian women ready to take control of their
          financial lives — no shame, no jargon, just what actually works.
        </p>
      </div>
      <div class="cover-side">
        <div class="cover-block">
          <span class="cb-tag"><PillarIcon pillar="earns" />She Earns More</span>
          <div class="cb-quote">Money is <em>permission</em> to live on your own terms.</div>
          <div class="cb-foot"><span class="cb-dot">F</span>sheisfem.com</div>
        </div>
      </div>
    </div>
  </header>

  <section class="section bg-cream diary-section" data-screen-label="Home — Field notes">
    <div class="wrap">
      <div class="spread">
        <div class="sp-left">
          <span class="kicker diary-kicker">From the diary</span>
          <div class="sp-left-main">
            <h2 class="sec-title" style="margin-bottom:.1em;">
              Small habits.<br />Compounding<br /><em>freedom.</em>
            </h2>
            <p class="lead">
              The latest notes on earning, building, investing, and living with more agency. Start
              here, then keep reading.
            </p>
            <a class="btn btn-peach" href="/blog">All diary entries</a>
          </div>
        </div>
        <div class="sp-right">
          <div class="sp-note">
            <span class="sp-note-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M12 20h9"></path>
                <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path>
              </svg>
            </span>
            Latest field notes
          </div>
          <div class="diary-posts">
            {
              recentPosts.map(({ slug, entry }) => (
                <a class="diary-post" href={`/blog/${slug}`}>
                  <span class="dp-filed">
                    <PillarIcon pillar={entry.pillar} />
                    {pillarLabels[entry.pillar] ?? entry.pillar}
                  </span>
                  <h3>{entry.title}</h3>
                  {entry.excerpt && <p>{entry.excerpt}</p>}
                  <span class="dp-foot">
                    {entry.publishedDate && <time datetime={entry.publishedDate}>{formatDate(entry.publishedDate)}</time>}
                    <span>Open entry →</span>
                  </span>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section tight wrap" data-screen-label="Home — Shortlist">
    <div class="sec-head">
      <div>
        <span class="kicker">Tools we actually use</span>
        <h2 class="sec-title">The shortlist</h2>
      </div>
      <a class="btn btn-ghost" href="/resources">All resources →</a>
    </div>
    <div class="r-list" style="margin-top:38px;">
      {
        featuredResources.map((resource) => (
          <ResourceRow
            href={resource.data.url}
            icon={getResourceIcon(resource.data.name)}
            name={resource.data.name}
            description={resource.data.description}
            external
          />
        ))
      }
    </div>
  </section>

  <section class="section peach newsletter-section" data-screen-label="Home — Newsletter CTA">
    <div class="wrap">
      <FolioBar left="Join the diary" middle="The newsletter" right="Straight to your inbox" />
      <div class="cta-grid" style="margin-top:52px;">
        <div>
          <div class="cta-text">She decided to start.<br /><em>That was the<br />hardest part.</em></div>
          <p class="cta-sub">
            Tools, tips, and real talk on building wealth your way — delivered to your inbox. No
            spam, no jargon, no permission required.
          </p>
          <span class="cta-script">— from the sheisfem diary</span>
        </div>
        <div class="news-panel">
          <form class="news-form" data-newsletter-form>
            <label class="news-label" for="news-email">Get the diary in your inbox</label>
            <p class="news-desc">
              A short note most weeks — the tools, habits, and ideas worth saving.
            </p>
            <div class="news-row">
              <input id="news-email" type="email" required placeholder="your@email.com" aria-label="Email address" />
              <button type="submit" class="btn btn-primary">
                Subscribe
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6"></path>
                </svg>
              </button>
            </div>
            <span class="news-fine">No spam. Unsubscribe anytime.</span>
            <p class="news-ok">You're in. Watch your inbox.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.querySelector("[data-newsletter-form]");
    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      form.querySelector(".news-row")?.setAttribute("style", "display:none");
      form.querySelector(".news-fine")?.setAttribute("style", "display:none");
      form.querySelector(".news-ok")?.setAttribute("style", "display:block");
    });
  </script>
</BaseLayout>
