---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Masthead from "../components/Masthead.astro";

interface Props {
  title: string;
  description?: string;
  active?: "home" | "about" | "resources" | "blog";
  type?: "website" | "article";
  image?: string;
}

const {
  title,
  description = "Tools, resources, and real talk for Canadian women ready to take control of their financial lives.",
  active = "home",
  type = "website",
  image = "/assets/fem-logo.png",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const imageUrl = new URL(image, Astro.site ?? Astro.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />
    <meta name="p:domain_verify" content="34dcd05c9209fdc7d3074ae2351b0b1a" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/assets/fem-logo.png" />
    <link rel="apple-touch-icon" href="/assets/fem-logo.png" />
    <meta property="og:site_name" content="SheisFEM" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Jost:wght@300;400;500;600&family=Caveat:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <Masthead active={active} />
    <slot />
    <Footer />
    <script is:inline>
      (() => {
        const getIsoIssueWeek = (date) => {
          const target = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
          const day = target.getUTCDay() || 7;
          target.setUTCDate(target.getUTCDate() + 4 - day);
          const yearStart = new Date(Date.UTC(target.getUTCFullYear(), 0, 1));
          return {
            week: Math.ceil(((target - yearStart) / 86400000 + 1) / 7),
            year: target.getUTCFullYear(),
          };
        };

        document.querySelectorAll("[data-current-issue-week]").forEach((element) => {
          const issueWeek = getIsoIssueWeek(new Date());
          element.textContent = `Issue No.${String(issueWeek.week).padStart(2, "0")} · ${issueWeek.year}`;
        });

        const burger = document.getElementById("navBurger");
        const links = document.getElementById("navLinks");
        burger?.addEventListener("click", () => {
          links?.classList.toggle("open");
        });
        document.addEventListener("click", (event) => {
          if (!links?.classList.contains("open")) {
            return;
          }

          const target = event.target;
          if (!(target instanceof Node)) {
            return;
          }

          if (!links.contains(target) && !burger?.contains(target)) {
            links.classList.remove("open");
          }
        });
        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            links?.classList.remove("open");
          }
        });
        links?.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            links.classList.remove("open");
          });
        });
      })();
    </script>
  </body>
</html>
